# Copy this file to .env.local and fill in your Supabase project values.
# Without these, the app runs in pure local-only mode (no cloud sync) — exactly
# as it does today. Sync + sign-in only activate once both are set.
#
# Find them in your Supabase project: Settings → API.
# The anon key is safe to expose in the browser — your data is protected by
# Row Level Security, not by hiding this key.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
